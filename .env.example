GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://example_user:example_password@postgres.lan:5432/example?sslmode=disable
GOOSE_MIGRATION_DIR=migration/postgres/examples/migrations
GOOSE_SEED_DIR=migration/postgres/examples/seeds
GOOSE_TABLE=examples.goose_db_version
GOOSE_SEED_TABLE=examples.goose_seed_version

